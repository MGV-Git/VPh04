# Скопируйте: cp .env.example .env && chmod 600 .env
# Затем: ./scripts/bootstrap.sh
#
# Если при `docker compose up -d --build` появляется DeadlineExceeded / context deadline exceeded
# (медленная сеть или первый pull базовых образов), увеличьте таймаут и повторите:
#   COMPOSE_HTTP_TIMEOUT=600 docker compose up -d --build
# Либо заранее: docker pull nginx:1.27-alpine python:3.12-slim-bookworm
#
# Если backend падает на «TLS handshake timeout» / «failed to fetch anonymous token» при pull
# python с docker.io — сеть до Docker Hub нестабильна или фильтруется. Варианты: повторить позже;
# docker pull python:3.12-slim-bookworm вручную; настроить /etc/docker/daemon.json «registry-mirrors»
# (зеркало вашего провайдера/VPN); или залогиниться в приватный registry и подставить свой FROM.

# PostgreSQL (только сеть app)
POSTGRES_USER=leads
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=leads

# Backend получает URL из этих переменных (см. docker-compose)
# DATABASE_URL задаётся в compose через POSTGRES_*

# pgAdmin (внутренний; снаружи только через Nginx + Basic Auth)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN

# Имена хостов в TLS (оба в SAN при ./scripts/bootstrap.sh) и server_name Nginx.
# Registry должен отличаться от основного сайта — иначе второй блок Nginx для /v2/ игнорируется.
NGINX_MAIN_SERVER_NAME=leads.local
NGINX_REGISTRY_SERVER_NAME=registry.leads.local

# Docker Registry (docker login по HTTPS); файлы htpasswd создаёт scripts/bootstrap.sh
REGISTRY_USER=registryuser
REGISTRY_PASSWORD=CHANGE_ME_REGISTRY

# Basic Auth Nginx для пути /pgadmin/ (отдельно от логина внутри pgAdmin)
PGADMIN_BASIC_USER=pgadmin
PGADMIN_BASIC_PASSWORD=CHANGE_ME_NGINX_BASIC

# Часовой пояс логов Watchtower
TZ=UTC

# Версия API Docker для Watchtower (при ошибке «client version 1.25 is too old» задайте ≥ 1.44)
# DOCKER_API_VERSION=1.44
